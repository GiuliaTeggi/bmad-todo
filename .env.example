# Environment variables for local development (npm run dev)
# Copy this file to .env

# Database (matches docker-compose db service defaults)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bmad_todo

# Backend
FRONTEND_ORIGIN=http://localhost:5173
NODE_ENV=development

# Docker Compose overrides (optional — defaults are set in docker-compose.yml)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=bmad_todo
# POSTGRES_PORT=5432
# BACKEND_PORT=3000
# FRONTEND_PORT=8080
# VITE_API_URL=http://localhost:3000
