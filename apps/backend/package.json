{
  "name": "@bmad-todo/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../../.env --import tsx/esm --watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=../../.env --import tsx/esm src/db/migrate.ts"
  },
  "dependencies": {
    "@bmad-todo/shared": "*",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.2.2",
    "fastify-type-provider-zod": "^4.0.2",
    "postgres": "^3.4.8",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "vitest": "^3.0.2"
  }
}
